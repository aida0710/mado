PORT=3000

# compose 内部 DNS で api コンテナ → postgres コンテナへ。host は `postgres` 固定。
DATABASE_URL_RW=postgres://dashboard_rw:CHANGEME@postgres:5432/dashboard
DATABASE_URL_RO=postgres://dashboard_ro:CHANGEME@postgres:5432/dashboard

# テストは host 上で vitest を直接実行するため localhost を使う (compose は postgres を 127.0.0.1:5432 に publish 済み)。
# 未設定でも api/routes/*.test.ts のフォールバックで同じ default が使われる。
DATABASE_URL_RW_TEST=postgres://dashboard_rw:CHANGEME@localhost:5432/dashboard_test

# 32 byte hex (openssl rand -hex 32)
# /api/external/metrics/push の Bearer 認証用
WRITE_TOKEN=
# storage_connections の S3 認証情報を AES-256-GCM で暗号化するキー
ENCRYPTION_KEY=

# CSRF 防御: /api/internal/* の write 系で許容する Origin (カンマ区切り、必須)。
# dev は Vite dev server、prod はダッシュボードを開く URL を入れる。
# 例: ALLOWED_ORIGINS=http://localhost:5173,http://lab-server
ALLOWED_ORIGINS=http://localhost:5173

PREVIEW_TEXT_LIMIT=65536
PREVIEW_TAR_ENTRY_LIMIT=200
PREVIEW_TARXZ_BYTE_LIMIT=268435456
