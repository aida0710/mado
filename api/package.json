{
  "name": "@web-dashboard/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:internal": "tsx watch --env-file=../.env internal.ts",
    "dev:external": "tsx watch --env-file=../.env external.ts",
    "build": "tsc -p tsconfig.json",
    "start:internal": "node dist/internal.js",
    "start:external": "node dist/external.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1039.0",
    "@hono/node-server": "^2.0.0",
    "hono": "^4.12.15",
    "lzma-native": "^8.0.6",
    "nanoid": "^5.0.0",
    "pg": "^8.20.0",
    "tar-stream": "^3.2.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@types/tar-stream": "^3.1.4",
    "aws-sdk-client-mock": "^4.1.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  }
}
