{
  "name": "web-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "front",
    "api"
  ],
  "scripts": {
    "dev": "concurrently -k -n web,server -c blue,magenta \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "npm --workspace front run dev",
    "dev:server": "npm --workspace api run dev",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm --workspace front run build",
    "build:server": "npm --workspace api run build",
    "start": "npm --workspace api run start",
    "test": "npm run test --workspaces --if-present",
    "test:web": "npm --workspace front run test",
    "test:server": "npm --workspace api run test",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
