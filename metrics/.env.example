# metrics ランナー / コレクター用の環境変数サンプル。
#
# このファイルを `.env` にコピーして値を入れると、`metrics/db.py` が
# import 時に自動で `os.environ` に流し込みます。`.env` は .gitignore
# 済 (秘密のトークンを誤コミットしないため)。
#
#   cp .env.example .env
#   $EDITOR .env       # 値を埋める
#
# CLI から `DASHBOARD_URL=... python3 runner.py ...` のように直接
# 渡した場合はそちらが優先されます (`.env` で上書きはしない)。

# ダッシュボードのベース URL。
# - prod (nginx 80 番) なら http://mado.example
# - dev (vite dev server) なら http://mado.example:5173
DASHBOARD_URL=http://mado.example

# Write 専用トークン (ダッシュボードの管理画面で発行)。
WRITE_TOKEN=replace-me-with-real-token
