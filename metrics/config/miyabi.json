{
  "host": "miyabi",
  "default_interval_seconds": 180,
  "commands": [
    {
      "category": "ノード使用率",
      "display_command": "qstat --rsc -b",
      "argv": ["qstat", "---rsc", "-b"],
      "interval_seconds": 60
    },
    {
      "category": "ジョブ使用率",
      "display_command": "qstat --limit",
      "argv": ["qstat", "--limit"],
      "interval_seconds": 60
    },
    {
      "category": "トークン使用率",
      "display_command": "qhost",
      "argv": ["qhost"],
      "interval_seconds": 60
    }
  ]
}
